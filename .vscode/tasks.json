{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (g++) -> build/",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "mkdir -p \"${fileDirname}/build\" && /usr/bin/g++ -std=c++17 -g -O0 \"${file}\" -o \"${fileDirname}/build/${fileBasenameNoExtension}\""
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++ 生成活动文件",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}