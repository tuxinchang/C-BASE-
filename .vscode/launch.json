{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ 万能调试",
            "type": "cppdbg",
            "request": "launch",
            // 核心黑科技：这个变量会自动找到 CMake 当前选中的启动目标
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}